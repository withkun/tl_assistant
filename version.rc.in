#if defined(UNDER_CE)
#   include <winbase.h>
#else
#   include <windows.h>
#endif
VS_VERSION_INFO VERSIONINFO
 FILEVERSION ${TL_PROJECT_VERSION_MAJOR}, ${TL_PROJECT_VERSION_MINOR}, ${TL_PROJECT_VERSION_PATCH}, ${TL_PROJECT_VERSION_TWEAK}
 PRODUCTVERSION ${TL_PROJECT_VERSION_MAJOR}, ${TL_PROJECT_VERSION_MINOR}, ${TL_PROJECT_VERSION_PATCH}, ${TL_PROJECT_VERSION_TWEAK}
 FILEFLAGSMASK 0x17L
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x4L
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "Comments", "TLFLOWARCH=x64-win64"
            VALUE "CompanyName", "TLeXX Software Ltd."
            VALUE "FileDescription", "TLFLOW Image Processing Library"
            VALUE "FileVersion", "${TL_PROJECT_VERSION_MAJOR}.${TL_PROJECT_VERSION_MINOR}.${TL_PROJECT_VERSION_PATCH}.${TL_PROJECT_VERSION_TWEAK}"
            VALUE "InternalName", "${PROJECT_NAME}"
            VALUE "LegalCopyright", "© TLeXX Software Ltd. 2012-2026"
            VALUE "OriginalFilename", "${PROJECT_NAME}.exe"
            VALUE "ProductName", "TLFLOW Progress Edition"
            VALUE "ProductVersion", "${TL_PROJECT_VERSION_MAJOR}.${TL_PROJECT_VERSION_MINOR}.${TL_PROJECT_VERSION_PATCH}.${TL_PROJECT_VERSION_TWEAK}"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END